generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String?
  role         Role          @default(STUDENT)
  attempts     Attempt[]
  savedQuestions SavedQuestion[]
  achievements UserAchievement[]
  dailyGoals   DailyGoal[]
  createdAt    DateTime      @default(now())
}

enum Role {
  STUDENT
  ADMIN
}

model Subject {
  id        String     @id @default(uuid())
  name      String     @unique
  exams     Exam[]
  questions Question[]
}

model Exam {
  id          String         @id @default(uuid())
  title       String
  category    String?
  durationMin Int
  subjectId   String
  subject     Subject        @relation(fields: [subjectId], references: [id])
  questions   ExamQuestion[]
  attempts    Attempt[]
  createdAt   DateTime       @default(now())
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  EXTREMELY_HARD
}

enum QuestionType {
  PART1_SINGLE_CHOICE
  PART2_TRUE_FALSE
  PART3_SHORT_ANSWER
}

model Question {
  id            String          @id @default(uuid())
  subjectId     String
  subject       Subject         @relation(fields: [subjectId], references: [id])
  topic         String?
  difficulty    DifficultyLevel @default(MEDIUM)
  type          QuestionType    @default(PART1_SINGLE_CHOICE)
  content       String          // LaTeX question body
  options       Json            // Array of options
  correctAnswer Json            // number | boolean[] | string
  explanation   String?         // Lời giải LaTeX
  exams         ExamQuestion[]
  savedBy       SavedQuestion[]
  tags          QuestionTag[]
}

model QuestionTag {
  id         String   @id @default(uuid())
  name       String   @unique
  questions  Question[]
}

model ExamQuestion {
  examId     String
  questionId String
  orderIndex Int
  exam       Exam     @relation(fields: [examId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])

  @@id([examId, questionId])
}

model Attempt {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  examId      String
  exam        Exam      @relation(fields: [examId], references: [id])
  score       Float?
  answers     Json      // Record<string, any>
  isFinished  Boolean   @default(false)
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
}

model SavedQuestion {
  id         String            @id @default(uuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  questionId String
  question   Question          @relation(fields: [questionId], references: [id])
  type       SavedQuestionType @default(STAR)
  notes      String?           // LaTeX notes
  createdAt  DateTime          @default(now())

  @@unique([userId, questionId, type])
}

enum SavedQuestionType {
  STAR
  INCORRECT
}

model Achievement {
  id          String   @id @default(uuid())
  title       String   @unique
  description String
  icon        String?
  users       UserAchievement[]
}

model UserAchievement {
  userId        String
  achievementId String
  user          User        @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())

  @@id([userId, achievementId])
}

model DailyGoal {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  date         DateTime @default(now())
  targetCount  Int      @default(20)
  currentCount Int      @default(0)
  isCompleted  Boolean  @default(false)

  @@unique([userId, date])
}
